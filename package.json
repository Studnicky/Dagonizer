{
  "name": "@noocodex/dagonizer-workspace",
  "version": "0.11.0",
  "private": true,
  "description": "Workspace root for the @noocodex/dagonizer monorepo.",
  "license": "MIT",
  "author": "Andrew Studnicky <a.j.studnicky@gmail.com>",
  "type": "module",
  "engines": {
    "node": ">=24",
    "pnpm": ">=10"
  },
  "scripts": {
    "build": "pnpm -r --filter \"./packages/*\" run build",
    "test": "pnpm -r --filter \"./packages/*\" run test",
    "typecheck": "pnpm -r --filter \"./packages/*\" run typecheck",
    "lint": "pnpm -r --filter \"./packages/*\" run lint",
    "lint:dags": "tsx scripts/lint-example-dags.ts",
    "ci": "pnpm run typecheck && pnpm run lint && pnpm run test && pnpm run lint:dags && pnpm run smoke:adapters",
    "smoke:adapters": "tsx examples/the-archivist/__smoke__/adapter-transport.smoke.ts",
    "changeset": "changeset",
    "version-packages": "changeset version && pnpm install --lockfile-only",
    "release": "pnpm run ci && changeset publish",
    "docs:dev": "vitepress dev docs",
    "docs:build": "pnpm run stamp-version && vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "docs:theme": "node docs/.vitepress/scripts/build-theme.mjs",
    "stamp-version": "node packages/dagonizer/scripts/stamp-version.mjs",
    "stamp-version:check": "node packages/dagonizer/scripts/stamp-version.mjs --check",
    "example:01": "tsx examples/01-linear.ts",
    "example:02": "tsx examples/02-builder.ts",
    "example:03": "tsx examples/03-schema.ts",
    "example:04": "tsx examples/04-scatter.ts",
    "example:05": "tsx examples/05-embedded-dags.ts",
    "example:06": "tsx examples/06-cancellation.ts",
    "example:07": "tsx examples/07-retry.ts",
    "example:08": "tsx examples/08-checkpoint.ts",
    "example:09": "tsx examples/09-terminals.ts",
    "example:10": "tsx examples/10-shared-state.ts",
    "example:derive": "tsx examples/derive.ts"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@noocodex/dagonizer": "workspace:^",
    "@noocodex/dagonizer-adapter-cerebras": "workspace:^",
    "@noocodex/dagonizer-adapter-gemini-api": "workspace:^",
    "@noocodex/dagonizer-adapter-gemini-nano": "workspace:^",
    "@noocodex/dagonizer-adapter-groq": "workspace:^",
    "@noocodex/dagonizer-adapter-mistral": "workspace:^",
    "@noocodex/dagonizer-adapter-ollama": "workspace:^",
    "@noocodex/dagonizer-adapter-openrouter": "workspace:^",
    "@noocodex/dagonizer-adapter-stub": "workspace:^",
    "@noocodex/dagonizer-adapter-web-llm": "workspace:^",
    "@noocodex/dagonizer-patterns-flow": "workspace:^",
    "@noocodex/dagonizer-patterns-graph": "workspace:^",
    "@noocodex/dagonizer-patterns-rag": "workspace:^",
    "@noocodex/dagonizer-book-entities": "workspace:^",
    "@noocodex/dagonizer-tool-googlebooks": "workspace:^",
    "@noocodex/dagonizer-tool-openlibrary": "workspace:^",
    "@noocodex/dagonizer-tool-wikipedia": "workspace:^",
    "tsx": "^4.20.0",
    "vitepress": "^1.6.4"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "unrs-resolver"
    ]
  }
}
