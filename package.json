{
  "name": "@noocodex/dagonizer-workspace",
  "version": "0.0.0",
  "private": true,
  "description": "Workspace root for the @noocodex/dagonizer monorepo.",
  "license": "MIT",
  "author": "Andrew Studnicky <a.j.studnicky@gmail.com>",
  "type": "module",
  "engines": {
    "node": ">=24",
    "pnpm": ">=10"
  },
  "scripts": {
    "build": "pnpm -r --filter \"./packages/*\" run build",
    "test": "pnpm -r --filter \"./packages/*\" run test",
    "typecheck": "pnpm -r --filter \"./packages/*\" run typecheck",
    "lint": "pnpm -r --filter \"./packages/*\" run lint",
    "ci": "pnpm run typecheck && pnpm run lint && pnpm run test && pnpm run smoke:adapters",
    "smoke:adapters": "tsx examples/the-archivist/__smoke__/adapter-transport.smoke.ts",
    "docs:dev": "vitepress dev docs",
    "docs:build": "pnpm run stamp-version && vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "docs:theme": "node docs/.vitepress/scripts/build-theme.mjs",
    "stamp-version": "node packages/dagonizer/scripts/stamp-version.mjs",
    "stamp-version:check": "node packages/dagonizer/scripts/stamp-version.mjs --check",
    "example:01": "tsx examples/01-linear.ts",
    "example:02": "tsx examples/02-builder.ts",
    "example:03": "tsx examples/03-schema.ts",
    "example:04": "tsx examples/04-fanout.ts",
    "example:05": "tsx examples/05-deepflows.ts",
    "example:06": "tsx examples/06-cancellation.ts",
    "example:07": "tsx examples/07-retry.ts",
    "example:08": "tsx examples/08-checkpoint.ts",
    "example:derive": "tsx examples/derive.ts"
  },
  "devDependencies": {
    "tsx": "^4.20.0",
    "vitepress": "^1.6.4"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "unrs-resolver"
    ]
  }
}
