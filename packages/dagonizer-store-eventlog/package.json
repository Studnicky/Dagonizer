{
  "name": "@studnicky/dagonizer-store-eventlog",
  "version": "0.30.1",
  "description": "Append-only event-log Store implementation for @studnicky/dagonizer. Every set appends an event; get returns the latest value by walking the log in reverse. Optional file persistence via node:fs/promises.",
  "license": "MIT",
  "author": "Andrew Studnicky <a.j.studnicky@gmail.com>",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "node": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "tsx --test tests/**/*.test.ts",
    "lint": "eslint . --max-warnings 0",
    "prepack": "npm run clean && npm run build"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://npm.pkg.github.com"
  },
  "devDependencies": {
    "@types/node": "^26.0.0"
  },
  "dependencies": {
    "@studnicky/clock": "^4.0.0",
    "@studnicky/concurrency": "^4.0.0"
  },
  "peerDependencies": {
    "@studnicky/dagonizer": "workspace:^0.30.0"
  },
  "engines": {
    "node": ">=24"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Studnicky/Dagonizer.git",
    "directory": "packages/dagonizer-store-eventlog"
  }
}
