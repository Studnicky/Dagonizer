{
  "name": "@studnicky/dagonizer-executor-node",
  "version": "0.23.0",
  "description": "Node.js isolating executor backends for @studnicky/dagonizer: worker threads, fork, cluster, and spawn over the bridge protocol.",
  "private": false,
  "license": "MIT",
  "author": "Andrew Studnicky <a.j.studnicky@gmail.com>",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "default": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist dist-test",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "pretest": "rm -rf dist-test && tsc -p tsconfig.test.json",
    "test": "node --test 'dist-test/tests/**/*.test.js'",
    "lint": "eslint . --max-warnings 0",
    "prepack": "npm run clean && npm run build"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://npm.pkg.github.com"
  },
  "engines": {
    "node": ">=24"
  },
  "dependencies": {
    "@studnicky/dagonizer": "workspace:>=0.23.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.2.0",
    "eslint": "^10.3.0",
    "eslint-plugin-import-x": "^4.16.2",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.59.3"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Studnicky/Dagonizer.git",
    "directory": "packages/dagonizer-executor-node"
  }
}
