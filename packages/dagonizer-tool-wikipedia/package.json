{
  "name": "@noocodex/dagonizer-tool-wikipedia",
  "version": "0.11.0",
  "description": "Tool plugin for @noocodex/dagonizer — Wikipedia.",
  "license": "MIT",
  "author": "Andrew Studnicky <a.j.studnicky@gmail.com>",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": { ".": { "default": "./dist/index.js", "types": "./dist/index.d.ts" } },
  "files": ["dist", "README.md"],
  "scripts": {
    "build":     "tsc -p tsconfig.json",
    "clean":     "rm -rf dist",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test":      "tsx --test tests/**/*.test.ts",
    "lint":      "echo 'lint via workspace root'",
    "prepack":   "npm run clean && npm run build"
  },
  "publishConfig": { "access": "public", "provenance": true },
  "devDependencies": { "@types/node": "^25.2.0" },
  "peerDependencies": { "@noocodex/dagonizer-book-entities": "workspace:>=0.11.0 <1.0.0", "@noocodex/dagonizer": "workspace:>=0.11.0 <1.0.0" },
  "engines": { "node": ">=24" },
  "repository": { "type": "git", "url": "git+https://github.com/Studnicky/Dagonizer.git", "directory": "packages/dagonizer-tool-wikipedia" }
}
