{
  "name": "@studnicky/dagonizer-embedder-tensorflow",
  "version": "1.0.0",
  "description": "Embedder plugin for @studnicky/dagonizer: UniversalSentenceEncoderEmbedder (in-browser embeddings via TensorFlow.js Universal Sentence Encoder, WASM + WebGL).",
  "license": "MIT",
  "author": "Andrew Studnicky <a.j.studnicky@gmail.com>",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "browser": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "tsx --test tests/**/*.test.ts",
    "lint": "eslint . --max-warnings 0",
    "prepack": "npm run clean && npm run build"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://npm.pkg.github.com"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "json-schema-to-ts": "^3.1.1"
  },
  "peerDependencies": {
    "@studnicky/dagonizer": "workspace:^1.0.0"
  },
  "engines": {
    "node": ">=24"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Studnicky/Dagonizer.git",
    "directory": "packages/dagonizer-embedder-tensorflow"
  },
  "dependencies": {
    "@tensorflow-models/universal-sentence-encoder": "^1.3.3",
    "@tensorflow/tfjs": "^4.22.0"
  }
}
