{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "declaration": false,
    "declarationMap": false,
    "noEmitOnError": false,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "outDir": "dist-test",
    "rootDir": ".",
    "sourceMap": true
  },
  "include": ["src/**/*.ts", "testing/**/*.ts", "tests/**/*.ts"],
  "exclude": ["dist", "dist-test", "dist-testing", "node_modules"]
}
