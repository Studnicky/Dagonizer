{
  "name": "@noocodex/dagonizer",
  "version": "0.11.3",
  "description": "DAG + FSM architecture framework for TypeScript. Type-safe nodes, abortable execution, deterministic resume, embedded-DAG composition, JSON-LD canonical wire format.",
  "private": false,
  "license": "MIT",
  "author": "Andrew Studnicky <a.j.studnicky@gmail.com>",
  "keywords": [
    "dag",
    "fsm",
    "state-machine",
    "workflow",
    "orchestration",
    "dispatcher",
    "pipeline",
    "graph",
    "embedded-dag",
    "directed-acyclic-graph",
    "framework",
    "typescript",
    "type-safe",
    "json-ld",
    "jsonld",
    "rdf",
    "schema",
    "ajv",
    "async-iterable",
    "abort-signal",
    "abortable",
    "cancellation",
    "retry",
    "retry-policy",
    "timeout",
    "checkpoint",
    "deterministic-resume",
    "observable",
    "lifecycle",
    "fan-out",
    "fan-in",
    "parallel",
    "composition",
    "browser",
    "node24",
    "esm",
    "agent-framework",
    "agent-orchestration",
    "ai-agent",
    "llm-orchestration",
    "tool-use",
    "function-calling",
    "rag",
    "sparql",
    "n3",
    "ontology",
    "owl",
    "named-graphs",
    "provenance",
    "prov-o",
    "task-graph"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Studnicky/Dagonizer.git"
  },
  "homepage": "https://github.com/Studnicky/Dagonizer#readme",
  "bugs": {
    "url": "https://github.com/Studnicky/Dagonizer/issues"
  },
  "type": "module",
  "sideEffects": false,
  "engines": {
    "node": ">=24"
  },
  "files": [
    "dist",
    "dist-testing",
    "LICENSE",
    "README.md",
    "CHANGELOG.md"
  ],
  "exports": {
    ".": {
      "default": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./adapter": {
      "default": "./dist/adapter/index.js",
      "types": "./dist/adapter/index.d.ts"
    },
    "./patterns": {
      "default": "./dist/patterns/index.js",
      "types": "./dist/patterns/index.d.ts"
    },
    "./tool": {
      "default": "./dist/tool/index.js",
      "types": "./dist/tool/index.d.ts"
    },
    "./errors": {
      "default": "./dist/errors/index.js",
      "types": "./dist/errors/index.d.ts"
    },
    "./constants": {
      "default": "./dist/constants.js",
      "types": "./dist/constants.d.ts"
    },
    "./lifecycle": {
      "default": "./dist/lifecycle/index.js",
      "types": "./dist/lifecycle/index.d.ts"
    },
    "./runtime": {
      "default": "./dist/runtime/index.js",
      "types": "./dist/runtime/index.d.ts"
    },
    "./builder": {
      "default": "./dist/builder/index.js",
      "types": "./dist/builder/index.d.ts"
    },
    "./validation": {
      "default": "./dist/validation/index.js",
      "types": "./dist/validation/index.d.ts"
    },
    "./entities": {
      "default": "./dist/entities/index.js",
      "types": "./dist/entities/index.d.ts"
    },
    "./checkpoint": {
      "default": "./dist/checkpoint/index.js",
      "types": "./dist/checkpoint/index.d.ts"
    },
    "./testing": {
      "default": "./dist-testing/index.js",
      "types": "./dist-testing/index.d.ts"
    },
    "./contracts": {
      "default": "./dist/contracts/index.js",
      "types": "./dist/contracts/index.d.ts"
    },
    "./core": {
      "default": "./dist/core/index.js",
      "types": "./dist/core/index.d.ts"
    },
    "./derive": {
      "default": "./dist/derive/index.js",
      "types": "./dist/derive/index.d.ts"
    },
    "./viz": {
      "default": "./dist/viz/index.js",
      "types": "./dist/viz/index.d.ts"
    },
    "./store": {
      "default": "./dist/store/index.js",
      "types": "./dist/store/index.d.ts"
    },
    "./types": {
      "default": "./dist/types/index.js",
      "types": "./dist/types/index.d.ts"
    }
  },
  "scripts": {
    "docs:dev": "vitepress dev docs",
    "predocs:build": "npm run stamp-version",
    "docs:build": "npm run docs:theme && vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "docs:theme": "node docs/.vitepress/scripts/build-palette.mjs",
    "docs:rasterize-og": "node scripts/rasterize-og-image.mjs",
    "stamp-version": "node scripts/stamp-version.mjs",
    "stamp-version:check": "node scripts/stamp-version.mjs --check",
    "clean": "rm -rf dist dist-test dist-testing",
    "build:src": "tsc -p tsconfig.json",
    "build:testing": "tsc -p tsconfig.testing.json",
    "build": "npm run build:src && npm run build:testing",
    "pretest": "rm -rf dist-test && tsc -p tsconfig.test.json",
    "test": "node --test 'dist-test/tests/**/*.test.js'",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix --max-warnings 0",
    "ci": "npm run typecheck && npm run lint && npm run test",
    "prepack": "npm run clean && npm run build",
    "prepublishOnly": "npm run ci"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "devDependencies": {
    "@cosmos.gl/graph": "^2.6.4",
    "@dagrejs/dagre": "^3.0.0",
    "@eslint/js": "^10.0.1",
    "@types/cytoscape": "^3.21.9",
    "@types/cytoscape-dagre": "^2.3.4",
    "@types/n3": "^1.26.1",
    "@types/node": "^25.2.0",
    "cytoscape": "^3.33.3",
    "cytoscape-dagre": "^3.0.0",
    "cytoscape-elk": "^2.3.0",
    "cytoscape-fcose": "^2.2.0",
    "eslint": "^10.3.0",
    "eslint-plugin-import-x": "^4.16.2",
    "mermaid": "^11.15.0",
    "n3": "^2.0.3",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.59.3",
    "vitepress": "^1.6.4",
    "vitepress-plugin-mermaid": "^2.0.17"
  },
  "dependencies": {
    "ajv": "^8.20.0",
    "json-schema-to-ts": "^3.1.1"
  },
  "dagonizer": {
    "seo": {
      "googleSiteVerification": "",
      "bingSiteVerification": "",
      "twitterHandle": ""
    }
  }
}
