      "types": "./dist/viz/index.d.ts",
      "default": "./dist/viz/index.js"
    },
    "./viz/explorer.css": "./dist/viz/explorer.css",
    "./store": {
      "types": "./dist/store/index.d.ts",
      "default": "./dist/store/index.js"
    },
    "./types": {
      "types": "./dist/types/index.d.ts",
      "default": "./dist/types/index.js"
    },
    "./container": {
      "types": "./dist/container/index.d.ts",
      "default": "./dist/container/index.js"
    },
    "./channels": {
      "types": "./dist/channels/index.d.ts",
