{
  "name": "@studnicky/dagonizer",
  "version": "2.0.0",
  "description": "DAG + FSM architecture framework for TypeScript. One engine for both LLM-agent orchestration and data-pipeline / ETL workflows. Type-safe nodes, abortable execution, streaming backpressure, deterministic resume, embedded-DAG composition, JSON-LD canonical wire format.",
  "private": false,
  "license": "MIT",
  "author": "Andrew Studnicky <a.j.studnicky@gmail.com>",
  "keywords": [
    "dag",
    "fsm",
    "state-machine",
    "workflow",
    "orchestration",
    "dispatcher",
    "pipeline",
    "graph",
    "embedded-dag",
    "directed-acyclic-graph",
    "framework",
    "typescript",
    "type-safe",
    "json-ld",
    "jsonld",
    "rdf",
    "schema",
    "ajv",
    "async-iterable",
    "abort-signal",
    "abortable",
    "cancellation",
    "retry",
    "retry-policy",
    "timeout",
    "checkpoint",
    "deterministic-resume",
    "observable",
    "lifecycle",
    "fan-out",
    "fan-in",
    "parallel",
    "composition",
    "browser",
    "node24",
    "esm",
    "agent-framework",
    "agent-orchestration",
    "ai-agent",
    "llm-orchestration",
    "tool-use",
    "function-calling",
    "rag",
    "sparql",
    "n3",
    "ontology",
    "owl",
    "named-graphs",
    "provenance",
    "prov-o",
    "task-graph",
    "streaming",
    "backpressure",
    "async-generator",
    "etl",
    "data-pipeline",
    "geospatial",
    "gdpr"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Studnicky/Dagonizer.git"
  },
  "homepage": "https://github.com/Studnicky/Dagonizer#readme",
  "bugs": {
    "url": "https://github.com/Studnicky/Dagonizer/issues"
  },
  "type": "module",
  "sideEffects": false,
  "engines": {
    "node": ">=24"
  },
  "files": [
    "dist",
    "dist-testing",
    "LICENSE",
    "README.md",
    "CHANGELOG.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./adapter": {
      "types": "./dist/adapter/index.d.ts",
      "default": "./dist/adapter/index.js"
    },
    "./patterns": {
      "types": "./dist/patterns/index.d.ts",
      "default": "./dist/patterns/index.js"
    },
    "./tool": {
      "types": "./dist/tool/index.d.ts",
      "default": "./dist/tool/index.js"
    },
    "./errors": {
      "types": "./dist/errors/index.d.ts",
      "default": "./dist/errors/index.js"
    },
    "./constants": {
      "types": "./dist/constants.d.ts",
      "default": "./dist/constants.js"
    },
    "./lifecycle": {
      "types": "./dist/lifecycle/index.d.ts",
      "default": "./dist/lifecycle/index.js"
    },
    "./runtime": {
      "types": "./dist/runtime/index.d.ts",
      "default": "./dist/runtime/index.js"
    },
    "./builder": {
      "types": "./dist/builder/index.d.ts",
      "default": "./dist/builder/index.js"
    },
    "./validation": {
      "types": "./dist/validation/index.d.ts",
      "default": "./dist/validation/index.js"
    },
    "./entities": {
      "types": "./dist/entities/index.d.ts",
      "default": "./dist/entities/index.js"
    },
    "./dag": {
      "types": "./dist/dag/index.d.ts",
      "default": "./dist/dag/index.js"
    },
    "./graph": {
      "types": "./dist/graph/index.d.ts",
      "default": "./dist/graph/index.js"
    },
    "./schema": {
      "types": "./dist/schema/index.d.ts",
      "default": "./dist/schema/index.js"
    },
    "./context": {
      "types": "./dist/context/index.d.ts",
      "default": "./dist/context/index.js"
    },
    "./checkpoint": {
      "types": "./dist/checkpoint/index.d.ts",
      "default": "./dist/checkpoint/index.js"
    },
    "./testing": {
      "types": "./dist-testing/index.d.ts",
