    },
    "./plugin": {
      "types": "./dist/plugin/index.d.ts",
      "default": "./dist/plugin/index.js"
    },
    "./observe": {
      "types": "./dist/ObservedDag.d.ts",
      "default": "./dist/ObservedDag.js"
    }
  },
  "scripts": {
    "docs:dev": "vitepress dev docs",
    "predocs:build": "npm run stamp-version",
    "docs:build": "npm run docs:theme && vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "docs:theme": "node docs/.vitepress/scripts/build-palette.mjs",
    "docs:rasterize-og": "node scripts/rasterize-og-image.mjs",
    "stamp-version": "node scripts/stamp-version.mjs",
    "stamp-version:check": "node scripts/stamp-version.mjs --check",
    "clean": "rm -rf dist dist-test dist-testing",
    "build:src": "tsc -p tsconfig.json && cp src/viz/explorer.css dist/viz/explorer.css",
    "build:testing": "tsc -p tsconfig.testing.json",
    "build": "npm run build:src && npm run build:testing",
    "pretest": "rm -rf dist dist-test dist-testing && tsc -p tsconfig.json && cp src/viz/explorer.css dist/viz/explorer.css && tsc -p tsconfig.testing.json && tsc -p tsconfig.test.json",
    "test": "node --test 'dist-test/tests/**/*.test.js'",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix --max-warnings 0",
    "ci": "npm run typecheck && npm run lint && npm run test",
    "prepack": "npm run clean && npm run build",
    "prepublishOnly": "npm run ci"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://npm.pkg.github.com"
  },
  "peerDependencies": {
    "@dagrejs/dagre": "^3.0.0",
    "cytoscape": "^3.33.3"
  },
  "peerDependenciesMeta": {
    "cytoscape": {
      "optional": true
    },
    "@dagrejs/dagre": {
      "optional": true
    }
  },
  "devDependencies": {
    "@cosmos.gl/graph": "^3.2.0",
    "@dagrejs/dagre": "^3.0.0",
    "@types/cytoscape-dagre": "^2.3.4",
    "@types/n3": "^1.26.1",
    "@types/node": "^26.1.1",
    "cytoscape": "^3.34.0",
    "cytoscape-dagre": "^4.0.0",
    "cytoscape-elk": "^2.3.0",
    "cytoscape-fcose": "^2.2.0",
    "mermaid": "^11.16.0",
    "n3": "^2.1.1",
    "tsx": "^4.23.0",
    "typescript": "^7.0.2",
    "vitepress": "^1.6.4",
    "vitepress-plugin-mermaid": "^2.0.17"
  },
  "dependencies": {
    "@studnicky/cache": "^5.0.0",
    "@studnicky/circular-buffer": "^5.0.0",
    "@studnicky/clock": "^5.0.0",
