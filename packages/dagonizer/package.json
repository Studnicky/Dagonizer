    "@studnicky/retry": "^5.0.0",
    "@studnicky/scheduler": "^5.0.0",
    "@studnicky/signal": "^5.0.0",
    "@studnicky/throttle": "^5.0.0",
    "@studnicky/timing": "^5.0.0",
    "@studnicky/types": "^5.0.0",
    "ajv": "^8.20.0",
